# Hakim AI - Enterprise Environment Configuration

# --- System ---
NODE_ENV=production
PORT=11455
NEXTAUTH_SECRET=your_super_secret_key_here
NEXTAUTH_URL=https://hakim.raidan.pro

# --- Admin Credentials (Auto-created on first run) ---
DEFAULT_ADMIN_EMAIL=admin@hakim.raidan.pro
DEFAULT_ADMIN_PASSWORD=change_this_immediately

# --- Database ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://hakim_user:hakim_password@localhost:5432/hakim_db

# --- AI & Edge Computing ---
GEMINI_API_KEY=your_gemini_api_key
OLLAMA_BASE_URL=http://127.0.0.1:11434
# MCP_SERVER_COMMAND=npx -y @modelcontextprotocol/server-postgres postgresql://...

# --- OAuth Providers ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# --- Storage & RAG Paths ---
VOICE_PRINT_DIR=/opt/hakim-ai/uploads/voice_prints
KNOWLEDGE_BASE_DIR=/opt/hakim-ai/knowledge_base

# --- SMTP (Email Notifications) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=hakim@raidan.pro
SMTP_PASSWORD=your_smtp_app_password
