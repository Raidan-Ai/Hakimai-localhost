# ----------------------------------------------------------------------
# SYSTEM & NEXT.JS CONFIGURATION
# ----------------------------------------------------------------------
# Set to 'production' for deployments. 'development' enables hot-reloading.
NODE_ENV=production

# The port the Next.js frontend will be accessible on.
PORT=11455

# The port the standalone backend/API server runs on (used for MCP, etc.).
BACKEND_PORT=11454

# A long, random string used for session encryption. Generate one with `openssl rand -base64 32`
NEXTAUTH_SECRET=

# The canonical URL of your deployment. Required for OAuth and callbacks.
# For local: http://localhost:11455
# For production: https://hakim.your-clinic.com
NEXTAUTH_URL=http://localhost:11455

# ----------------------------------------------------------------------
# INITIAL ADMIN ACCOUNT (Created on first database seed)
# ----------------------------------------------------------------------
# The email for the default Super Admin account.
DEFAULT_ADMIN_EMAIL=admin@hakim.ai

# The password for the default Super Admin. CHANGE THIS IN A .env FILE.
DEFAULT_ADMIN_PASSWORD=password

# ----------------------------------------------------------------------
# DATABASE CONNECTION
# ----------------------------------------------------------------------
# The connection string for your database. Prisma supports PostgreSQL, MySQL, SQLite, etc.

# Example for PostgreSQL (Cloud Deployment):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Example for SQLite (Local Bare-Metal/Laptop Deployment):
DATABASE_URL="file:./medical.db"

# ----------------------------------------------------------------------
# ARTIFICIAL INTELLIGENCE & MCP (Model Context Protocol)
# ----------------------------------------------------------------------
# The base URL for the Ollama server, which runs the local AI models.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# The server command to start the Model Context Protocol for local file access.
# This allows the AI to securely read files from a designated local directory.
MCP_SERVER_COMMAND="node /opt/hakim-ai/mcp-server/index.js"

# API Key for Google Gemini, used for non-PHI cloud-based reasoning.
GEMINI_API_KEY=

# ----------------------------------------------------------------------
# STORAGE & EXTERNAL APIS
# ----------------------------------------------------------------------
# The absolute path on the server where uploaded files are stored temporarily.
# Ensure this directory exists and has the correct permissions.
LOCAL_UPLOAD_DIR=/opt/hakim-ai/uploads

# Google Drive API Credentials for the file picker functionality.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=

# ----------------------------------------------------------------------
# SMTP EMAIL SERVER (for notifications, password resets, etc.)
# ----------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_EMAIL=hakim@raidan.pro
SMTP_PASSWORD=
