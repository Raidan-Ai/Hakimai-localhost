#
# Hakim AI - Environment Configuration
# RaidanPro | 2024
#
# This file provides a template for the required environment variables.
# Copy this file to .env and fill in the values for your specific environment.

# -------------------------------------
# SYSTEM & NEXTAUTH CONFIGURATION
# -------------------------------------
# Set to 'development' or 'production'
NODE_ENV=development

# Port for the Next.js frontend application
PORT=11455

# Port for the backend server (Express.js)
BACKEND_PORT=11454

# A secret for NextAuth.js session encryption. Generate with `openssl rand -base64 32`
NEXTAUTH_SECRET=

# The canonical URL of your application for NextAuth.js callbacks
# For local development: http://localhost:11455
# For production: https://hakim.your-domain.com
NEXTAUTH_URL=http://localhost:11455

# -------------------------------------
# SUPER ADMIN CREDENTIALS
# -------------------------------------
# Initial credentials for the first Super Admin user, created on `prisma db seed`
DEFAULT_ADMIN_EMAIL=admin@hakim.ai
DEFAULT_ADMIN_PASSWORD=ChangeMeASAP!

# -------------------------------------
# DATABASE CONNECTION
# -------------------------------------
# Option 1: PostgreSQL (Recommended for Cloud/Production)
# Example: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=

# Option 2: SQLite (For Local/Bare-Metal Development)
# Example: DATABASE_URL="file:./medical.db"

# -------------------------------------
# AI & MCP (Model Context Protocol)
# -------------------------------------
# Base URL for the local Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# Command to start the MCP server (if applicable)
MCP_SERVER_COMMAND=

# API Key for Google Gemini (for non-local, advanced models)
GEMINI_API_KEY=

# -------------------------------------
# STORAGE & FILE HANDLING
# -------------------------------------
# Directory for local file uploads (PHI-sensitive data)
LOCAL_UPLOAD_DIR=./uploads

# Google Drive API Credentials for doctor file access
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=

# -------------------------------------
# OAUTH PROVIDERS (for user login)
# -------------------------------------
# Google OAuth Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn OAuth Credentials
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# -------------------------------------
# SMTP FOR EMAIL NOTIFICATIONS
# -------------------------------------
SMTP_HOST=
SMTP_PORT=
SMTP_EMAIL=
SMTP_PASSWORD=
