// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://localhost:5432/hakim"
}

// Note: SQLite does not support Enums. For dual-compatibility, 
// we use String and handle roles in application logic.

model SystemConfig {
  id            String   @id @default("default")
  baseUrl       String   @default("http://localhost:11455")
  aiMode        String   @default("CLOUD") // CLOUD, LOCAL_EDGE, HYBRID
  activeCloud   String   @default("GEMINI") // GEMINI, OPENAI, ANTHROPIC
  ollamaUrl     String   @default("http://127.0.0.1:11434")
  remoteGpuUrl  String?  // e.g., RunPod, Vast.ai endpoint
  n8nWebhookUrl String?  // For agent automation
  ttsMaleModel  String?  @default("tts-1")
  ttsFemaleModel String? @default("tts-1-hd")
  publicTrialEnabled Boolean @default(false)
  trialMessageLimit Int @default(10)
  googleClientId String?
  googleClientSecret String?
  linkedinClientId String?
  linkedinClientSecret String?
  isGoogleLoginEnabled Boolean @default(false)
  isLinkedinLoginEnabled Boolean @default(false)
  updatedAt     DateTime @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
model TrialUser {
  id          String   @id @default(cuid())
  messageCount Int      @default(0)
  createdAt   DateTime @default(now())
}

enum Role {
  ADMIN
  DOCTOR
}

model ApiKey {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  userId    String   // Admin user who created the key
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  expiresAt DateTime?
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(DOCTOR)
  accounts      Account[]
  sessions      Session[]

  // Doctor-specific fields
  specialization String?  // e.g., Cardiology, Neurology
  bio           String?  @db.Text
  themePreference String? @default("light") // 'light' or 'dark'

  // Relationships
  clinicId      String?
  cases         Case[]
  auditLogs     AuditLog[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  apiKeys       ApiKey[]
  googleDriveTokens UserGoogleDriveToken[]

  @@index([clinicId])
}

model Patient {
  id                      String   @id @default(cuid())
  name                    String
  dateOfBirth             DateTime
  encryptedMedicalHistory String   // Removed @db.Text for SQLite compatibility
  cases                   Case[]
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([name])
}

model Case {
  id           String   @id @default(cuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id])
  doctorId     String
  doctor       User     @relation(fields: [doctorId], references: [id])
  aiModelUsed  String
  summary      String   // Removed @db.Text for SQLite compatibility
  status       String   @default("OPEN") // OPEN, REVIEWED, CLOSED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([patientId])
  @@index([doctorId])
}

model TriageData {
  id                String   @id @default(cuid())
  symptomsText      String   // Removed @db.Text for SQLite compatibility
  geographicLocation String?
  timestamp         DateTime @default(now())

  @@index([timestamp])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  resource  String
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([timestamp])
}

model UserGoogleDriveToken {
  id          String   @id @default(cuid())
  userId      String   @unique
  accessToken String
  refreshToken String
  expiryDate  DateTime
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
