// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://localhost:5432/hakim"
}

// Note: SQLite does not support Enums. For dual-compatibility, 
// we use String and handle roles in application logic.

model SystemConfig {
  id            String   @id @default("default")
  baseUrl       String   @default("http://localhost:11455")
  aiMode        String   @default("CLOUD") // CLOUD, LOCAL_EDGE, HYBRID
  activeCloud   String   @default("GEMINI") // GEMINI, OPENAI, ANTHROPIC
  ollamaUrl     String   @default("http://127.0.0.1:11434")
  remoteGpuUrl  String?  // e.g., RunPod, Vast.ai endpoint
  n8nWebhookUrl String?  // For agent automation
  updatedAt     DateTime @updatedAt
}

model ApiKey {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  userId    String   // Admin user who created the key
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  expiresAt DateTime?
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         String     @default("DOCTOR") // Use String for SQLite compatibility
  clinicId     String?
  cases        Case[]
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  apiKeys      ApiKey[]

  @@index([clinicId])
}

model Patient {
  id                      String   @id @default(cuid())
  name                    String
  dateOfBirth             DateTime
  encryptedMedicalHistory String   // Removed @db.Text for SQLite compatibility
  cases                   Case[]
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([name])
}

model Case {
  id           String   @id @default(cuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id])
  doctorId     String
  doctor       User     @relation(fields: [doctorId], references: [id])
  aiModelUsed  String
  summary      String   // Removed @db.Text for SQLite compatibility
  status       String   @default("OPEN") // OPEN, REVIEWED, CLOSED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([patientId])
  @@index([doctorId])
}

model TriageData {
  id                String   @id @default(cuid())
  symptomsText      String   // Removed @db.Text for SQLite compatibility
  geographicLocation String?
  timestamp         DateTime @default(now())

  @@index([timestamp])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  resource  String
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([timestamp])
}
