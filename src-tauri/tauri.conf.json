{
  "productName": "Hakim AI",
  "version": "2.0.0",
  "identifier": "pro.raidan.hakim",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hakim AI - Clinical Decision Support",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "label": "main"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:11434 http://localhost:3000; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com;",
      "capabilities": [
        "core:default",
        "window:default"
      ],
      "freezePrototype": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": []
  },
  "plugins": {
    "shell": {
      "scope": [
        {
          "name": "ollama",
          "cmd": "ollama",
          "sidecar": false
        }
      ]
    }
  }
}
